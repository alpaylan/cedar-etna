{
  "setup_steps": [
    {
      "Command": {
        "command": "bash",
        "args": ["-c", "cd cedar-lean && lake update"]
      }
    }
  ],
  "build_steps": [
    {
      "Command": {
        "command": "bash",
        "args": ["-c", "cd cedar-lean && lake build etna_cedar"]
      }
    }
  ],
  "capabilities": {
    "solve": [
      {
        "Command": {
          "command": "bash",
          "args": ["-c", "cd cedar-lean && lake exe etna_cedar ${strategy} ${property}"],
          "params": ["property", "strategy"]
        }
      }
    ]
  }
}
